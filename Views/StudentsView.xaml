<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="UniversityMenuApp.Views.StudentsView" Height="356" Width="524"
             >
    <Grid Margin="24">

        <StackPanel>
            <TextBlock Text="Mantenimiento de Alumnos" FontSize="22" FontWeight="SemiBold"/>
        </StackPanel>
        <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Left" Height="15" Margin="238,113,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="151"/>
        <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Height="16" Margin="238,158,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="151"/>


        <DataGrid Grid.Column="0"
                  HorizontalAlignment="Left" 
                  Height="130" 
                  Margin="0,93,0,0" 
                  VerticalAlignment="Top" 
                  Width="224" 
                  ItemsSource="{Binding Students}"
                  SelectedItem="{Binding SelectedStudent}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Eliminar"  Command="{Binding DeleteStudentCommand}" HorizontalAlignment="Left" Margin="388,193,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="60"/>
        <Button Content="Agregar"  Command="{Binding AddStudentCommand}" HorizontalAlignment="Left" Margin="234,193,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="60"/>
        <Label Content="Nombre" HorizontalAlignment="Left" Margin="238,93,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label Content="Gmail" HorizontalAlignment="Left" Margin="238,136,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Button Content="Modificar" Command="{Binding UpdateStudentCommand}" HorizontalAlignment="Left" Margin="304,193,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="70"/>
        <Button Content="Exportar" Command="{Binding ExportToExcelCommand}"  HorizontalAlignment="Left" Margin="396,278,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="70"/>
    </Grid>
</UserControl>