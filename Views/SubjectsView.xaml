<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="UniversityMenuApp.Views.SubjectsView"
             Height="311" Width="472">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Mantenimiento de Asignaturas" FontSize="22" FontWeight="SemiBold"/>
        </StackPanel>
        <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Left" Height="15" Margin="238,113,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="133"/>

        <DataGrid Grid.Column="0"
                  HorizontalAlignment="Left" 
                  Height="130" 
                  Margin="0,93,0,0" 
                  VerticalAlignment="Top" 
                  Width="199" 
                  ItemsSource="{Binding Subjects}"
                  SelectedItem="{Binding SelectedSubject}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Nombre de la Asignatura" HorizontalAlignment="Left" Margin="229,93,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Button Content="Agregar" Command="{Binding AddSubjectCommand}" HorizontalAlignment="Left" Margin="212,138,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="55"/>
        <Button Content="Eliminar" Command="{Binding DeleteSubjectCommand}" HorizontalAlignment="Left" Margin="352,138,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="55"/>
        <Button Content="Modificar" Command="{Binding UpdateSubjectCommand}" HorizontalAlignment="Left" Margin="275,138,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="70"/>
        <Button Content="Exportar" Command="{Binding ExportToExcelCommand}" HorizontalAlignment="Left" Margin="344,233,0,0" VerticalAlignment="Top" FontWeight="Bold" Width="70"/>

    </Grid>
</UserControl>